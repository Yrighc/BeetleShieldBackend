SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=beetleshield
DB_PASSWORD=beetleshield
DB_NAME=beetleshield
DB_SSLMODE=disable

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=24

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=beetleshield
MINIO_SECRET_KEY=beetleshield123
MINIO_USE_SSL=false
MINIO_BUCKET=beetleshield-apps

MAX_UPLOAD_SIZE_MB=4096

DPT_JAR_PATH=/Users/yrighc/work/hzyz/project/test/dpt-shell/executable/dpt.jar
DPT_WORK_DIR=/tmp/beetleshield-hardening
# DPT_DEFAULT_VMP_RULES uses the built-in default two-line VMP rule.
DPT_TASK_TIMEOUT_MINUTES=60
HARDENING_ENGINE_VERSION=BeetleShield Engine v2.4.1

ADMIN_EMAIL=admin@beetleshield.com
ADMIN_PASSWORD=ChangeMe123!

# STATIC_DIR is unset for local `go run` dev (frontend runs separately via
# `npm run dev`). docker-compose.yml sets it to /app/web for the packaged
# full-stack container — see docs/deployment.md "Docker 化部署".
# STATIC_DIR=
